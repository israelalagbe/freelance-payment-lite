# Server
PORT=3001
NODE_ENV=development

# MongoDB connection string (replica set required for transactions)
MONGODB_URI=mongodb://127.0.0.1:27017/freelance_payment

# Business rules — tweak without touching code
DEPOSIT_LIMIT_PCT=0.25
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_ANALYTICS_MAX=30
